<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FastFluentFilesFolders.Views.PluginsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:comCtrls="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="14" HorizontalAlignment="Stretch">
            <TextBlock Text="插件管理" FontSize="22" FontWeight="Bold" />
            <TextBlock Text="Plugin Management" FontSize="14" Foreground="Gray" />

            <!-- Import -->
            <comCtrls:SettingsCard Header="导入插件" x:Name="ImportCard">
                <comCtrls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE8A7;" />
                </comCtrls:SettingsCard.HeaderIcon>
                <Button x:Name="ImportBtn" Click="OnImportClick"
                        Style="{StaticResource AccentButtonStyle}"
                        Content="选择 .zip 导入" />
            </comCtrls:SettingsCard>

            <!-- Installed plugins list -->
            <StackPanel x:Name="InstalledSection" Visibility="Collapsed">
                <TextBlock Text="已安装的插件" FontSize="16" FontWeight="SemiBold" Margin="0,12,0,0"/>
                <ListView x:Name="InstalledList" Height="200" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Grid ColumnSpacing="8" Padding="4,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis" FontWeight="SemiBold"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="&#xE74D;"
                                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                                        Style="{StaticResource SubtleButtonStyle}"
                                        Click="OnUninstallClick"
                                        Tag="{Binding}" Width="32" Height="32"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <!-- Plugin settings -->
            <StackPanel x:Name="PluginSettingsSection" Visibility="Collapsed">
                <TextBlock Text="插件设置" FontSize="16" FontWeight="SemiBold" Margin="0,12,0,0"/>
                <StackPanel x:Name="PluginSettingsStack" Spacing="14" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
