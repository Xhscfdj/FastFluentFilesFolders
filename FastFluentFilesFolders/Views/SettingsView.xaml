<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FastFluentFilesFolders.Views.SettingsView"
    x:Name="SV"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FastFluentFilesFolders.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ctrls="using:Microsoft.UI.Xaml.Controls"
    xmlns:ccl="using:CommunityToolkit.WinUI.Controls"
    xmlns:vm="using:FastFluentFilesFolders.ViewModels"
    mc:Ignorable="d"
    NavigationCacheMode="Required"
    IsTabStop="True"
    KeyDown="OnSettingsViewKeyDown">
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="*"    />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>
		<ScrollViewer>
			<StackPanel Padding="24" Spacing="14" HorizontalAlignment="Stretch" x:Name="SettingsStack">
				<TextBlock Text="{Binding ML.SettingsTitle}"  Style="{StaticResource TitleTextBlockStyle}"/>
				<!--General-->
				<TextBlock Text="{Binding ML.GeneralSection}" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,12,0,0" />
				<ccl:SettingsCard Header="{Binding ML.HomePagePath}">
					<ccl:SettingsCard.HeaderIcon>
						<FontIcon Glyph="&#xE80F;" />
					</ccl:SettingsCard.HeaderIcon>
					<TextBox Text="{Binding AppConfigs.HomePageFullPath, Mode=TwoWay}" />
				</ccl:SettingsCard>

				<ccl:SettingsCard Header="{Binding ML.LanguageLabel}">
					<ccl:SettingsCard.HeaderIcon>
						<FontIcon Glyph="&#xE8B1;" />
					</ccl:SettingsCard.HeaderIcon>
					<ComboBox ItemsSource="{Binding LanguageOptions}"
							  SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
							  DisplayMemberPath="DisplayName" />
				</ccl:SettingsCard>

				<ccl:SettingsExpander Header="{Binding ML.DefaultSortOrder}">
					<ccl:SettingsExpander.HeaderIcon>
						<FontIcon Glyph="&#xE8CB;" />
					</ccl:SettingsExpander.HeaderIcon>
					<ccl:SettingsExpander.Items>
						<ccl:SettingsCard Header="{Binding ML.SortBy}">
							<ccl:SettingsCard.HeaderIcon>
								<FontIcon Glyph="&#xE8CB;" />
							</ccl:SettingsCard.HeaderIcon>
							<ComboBox SelectedItem="{Binding SelectedOrderModeItem, Mode=TwoWay}" ItemsSource="{Binding OrderModeItems}" DisplayMemberPath="Display"/>
						</ccl:SettingsCard>
					</ccl:SettingsExpander.Items>
				</ccl:SettingsExpander>

				<!--Appearance-->
				<TextBlock Text="{Binding ML.AppearanceSection}" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,8,0,0" />
				<ccl:SettingsCard Header="{Binding ML.MiddleFilesHeight}">
					<ccl:SettingsCard.HeaderIcon>
						<FontIcon Glyph="&#xE752;" />
					</ccl:SettingsCard.HeaderIcon>
					<ctrls:NumberBox Value="{Binding AppConfigs.MiddleFilesHeight, Mode=TwoWay}"
									 Minimum="20" Maximum="200"
									 SpinButtonPlacementMode="Inline" />
				</ccl:SettingsCard>

				<TextBlock Text="{Binding ML.AdvancedSection}" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,12,0,0" />
				<ccl:SettingsCard Header="{Binding ML.UseWin32Icon}">
					<ccl:SettingsCard.HeaderIcon>
						<FontIcon Glyph="&#xE770;"/>
					</ccl:SettingsCard.HeaderIcon>
					<ToggleSwitch IsOn="{Binding AppConfigs.IfUsesWin32APIToGetIcon, Mode=TwoWay}" />
				</ccl:SettingsCard>

				<TextBlock Text="{Binding ML.PerformanceSection}" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,12,0,0" />
				<ccl:SettingsCard Header="{Binding ML.IconParallelLoading}">
					<ccl:SettingsCard.HeaderIcon>
						<FontIcon Glyph="&#xE8B9;"/>
					</ccl:SettingsCard.HeaderIcon>
					<ctrls:NumberBox Value="{Binding AppConfigs.IconParallelLoadingCount, Mode=TwoWay}"
									 Minimum="1" Maximum="200"
									 SpinButtonPlacementMode="Inline" />
				</ccl:SettingsCard>

				<TextBlock Text="{Binding ML.DebugSection}" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,12,0,0"/>

				<ccl:SettingsExpander Header="{Binding ML.TimeGroupedFoldersHeader}">
					<ccl:SettingsExpander.HeaderIcon>
						<FontIcon Glyph="&#xE8B7;" />
					</ccl:SettingsExpander.HeaderIcon>
					<ccl:SettingsExpander.Items>
						<ccl:SettingsCard>
							<ListView ItemsSource="{Binding TimeGroupedFolders}" Height="120"
									  SelectionMode="None">
								<ListView.ItemTemplate>
									<DataTemplate x:DataType="x:String">
										<Grid ColumnSpacing="8">
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="*"/>
												<ColumnDefinition Width="Auto"/>
											</Grid.ColumnDefinitions>
											<TextBlock Text="{Binding}" VerticalAlignment="Center"
													   TextTrimming="CharacterEllipsis"/>
											<Button Grid.Column="1"
													Content="&#xE74D;"
													FontFamily="{StaticResource SymbolThemeFontFamily}"
													Style="{StaticResource SubtleButtonStyle}"
													Command="{Binding DataContext.DeleteTimeGroupedFolderCommand, ElementName=SV}"
													CommandParameter="{Binding}"
													Width="32" Height="32"/>
										</Grid>
									</DataTemplate>
								</ListView.ItemTemplate>
							</ListView>
						</ccl:SettingsCard>
						<ccl:SettingsCard>
							<StackPanel Spacing="8" Orientation="Horizontal">
								<TextBox Text="{Binding NewTimeGroupedFolderPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
										 PlaceholderText="{Binding ML.TimeGroupedFolderPlaceholder}"
										 MinWidth="280"/>
								<Button Command="{Binding AddTimeGroupedFolderCommand}"
										Content="{Binding ML.AddTimeGroupedFolder}"
										Style="{StaticResource AccentButtonStyle}"/>
							</StackPanel>
						</ccl:SettingsCard>
					</ccl:SettingsExpander.Items>
				</ccl:SettingsExpander>

				<TextBlock Text="{Binding ML.DebugSection}" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,12,0,0"/>
				<ccl:SettingsCard Header="{Binding ML.UserConfigPath}">
					<ccl:SettingsCard.HeaderIcon>
						<FontIcon Glyph="&#xE756;" />
					</ccl:SettingsCard.HeaderIcon>
					<TextBlock Text="{Binding ConfigFilePath}" />
				</ccl:SettingsCard>

				<!-- Plugins Section -->
				<StackPanel x:Name="PluginsSection" Visibility="Collapsed">
					<TextBlock Text="{Binding ML.PluginsSection}" FontSize="16" FontWeight="SemiBold" Margin="0,12,0,0"/>
					<StackPanel x:Name="PluginSettingsStack" Spacing="14" />
				</StackPanel>

				<TextBlock Text="{Binding ML.PluginManagement}" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,12,0,0"/>
				<ccl:SettingsCard Header="{Binding ML.PluginImport}">
					<ccl:SettingsCard.HeaderIcon>
						<FontIcon Glyph="&#xE8A7;" />
					</ccl:SettingsCard.HeaderIcon>
					<Button x:Name="ImportPluginBtn" Click="OnImportPluginClick"
							Style="{StaticResource AccentButtonStyle}"
							Content="{Binding ML.PluginImportBtn}" />
				</ccl:SettingsCard>

				<ccl:SettingsCard x:Name="InstalledPluginsCard"
									   Header="{Binding ML.PluginInstalled}"
									   Visibility="Collapsed">
					<ccl:SettingsCard.HeaderIcon>
						<FontIcon Glyph="&#xE943;" />
					</ccl:SettingsCard.HeaderIcon>
					<ListView x:Name="InstalledPluginsList" Height="200"
							  SelectionMode="None">
						<ListView.ItemTemplate>
							<DataTemplate x:DataType="x:String">
								<Grid ColumnSpacing="8">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*"/>
										<ColumnDefinition Width="Auto"/>
									</Grid.ColumnDefinitions>
									<StackPanel VerticalAlignment="Center">
										<TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis"
												   FontWeight="SemiBold"/>
									</StackPanel>
									<Button Grid.Column="1"
											Content="&#xE74D;"
											FontFamily="{StaticResource SymbolThemeFontFamily}"
											Style="{StaticResource SubtleButtonStyle}"
											Click="OnUninstallPluginClick"
											Tag="{Binding}"
											Width="32" Height="32"/>
								</Grid>
							</DataTemplate>
						</ListView.ItemTemplate>
					</ListView>
				</ccl:SettingsCard>

				<TextBlock Text="{Binding ML.AboutSection}" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,12,0,0"/>
				<ccl:SettingsExpander>
					<ccl:SettingsExpander.Header>
						<StackPanel>
							<TextBlock Text="FastFluentFilesFolders" />
							<TextBlock Text="By Xhscfdj" Foreground="Gray" FontSize="14"/>
						</StackPanel>
					</ccl:SettingsExpander.Header>
					<ccl:SettingsExpander.Content>
						<TextBlock Text="1.0.0-beta" />
					</ccl:SettingsExpander.Content>
					<ccl:SettingsExpander.HeaderIcon>
						<FontIcon Glyph="&#xE946;" />
					</ccl:SettingsExpander.HeaderIcon>
					<ccl:SettingsExpander.Items>
						<ccl:SettingsCard>
							<HyperlinkButton NavigateUri="https://www.github.com/Xhscfdj/">
								<StackPanel Orientation="Horizontal">
									<TextBlock Text="{Binding ML.AuthorTip}" Margin="0,0,10,0" />
									<TextBlock Text="Xhscfdj" />
								</StackPanel>
							</HyperlinkButton>
						</ccl:SettingsCard>
						<ccl:SettingsCard>
							<HyperlinkButton NavigateUri="https://www.github.com/Xhscfdj/FastFluentFilesFolders">
								<StackPanel Orientation="Horizontal">
									<TextBlock Text="{Binding ML.RepositoryTip}" Margin="0,0,10,0" />
									<TextBlock Text="FastFluentFilesFolders" />
								</StackPanel>
							</HyperlinkButton>
						</ccl:SettingsCard>
					</ccl:SettingsExpander.Items>
				</ccl:SettingsExpander>
			</StackPanel>
		</ScrollViewer>
		<Button x:Name="SaveButton" Click="SaveSettings" Margin="14,12,0,0"
				Grid.Row="1" Style="{StaticResource AccentButtonStyle}"
                HorizontalAlignment="Left" Content="{Binding ML.SaveSettings}"/>
	</Grid>
</Page>
