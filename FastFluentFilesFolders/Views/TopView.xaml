<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FastFluentFilesFolders.Views.TopView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FastFluentFilesFolders.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:BBB="using:BetterBreadcrumbBar.Control"
	xmlns:vm="using:FastFluentFilesFolders.ViewModels"
	xmlns:services="using:FastFluentFilesFolders.Services"
	xmlns:LRSCtrls="using:FastFluentFilesFolders.UserControls"
	d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}"
    mc:Ignorable="d">

	<Grid>
		<LRSCtrls:LRSBreadcrumb x:Name="BreadcrumbCtrl" CurrentPath="{Binding SelectedFolder.FullPath, Mode=OneWay}"
								NavigateCommand="{Binding NavigateToPathCommand}"
								Margin="10,0,10,0"
								Height="35"
								NavigateSubCommand="{Binding NavigateToSubFolderCommand}"
								GoBackCommand="{Binding GoBackCommand}"
								GoForwardCommand="{Binding GoForwardCommand}"
								GoUpCommand="{Binding GoUpCommand}"
								CanGoBack="{Binding CanGoBack}"
								CanGoForward="{Binding CanGoForward}"
								HomePath="{Binding AppConfigs.HomePageFullPath}">
		</LRSCtrls:LRSBreadcrumb>
	</Grid>
</Page>
