<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:LRS.UserControls.TableView"
                    xmlns:controls="using:LRS.UserControls.TableView.Controls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Resources.xaml" />
        <ResourceDictionary Source="TableView.xaml" />
        <ResourceDictionary Source="TableViewCell.xaml" />
        <ResourceDictionary Source="TableViewRowPresenter.xaml" />
        <ResourceDictionary Source="TableViewColumnHeader.xaml" />
        <ResourceDictionary Source="TableViewHeaderRow.xaml" />
        <ResourceDictionary Source="TableViewRow.xaml" />
        <ResourceDictionary Source="TableViewRowHeader.xaml" />
        <ResourceDictionary Source="TableViewTimePicker.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--Hack for auto generated resize issue-->
    <local:TableViewTextColumn x:Key="ThisNeedsToBeHere" />

    <Style TargetType="local:TableViewRowHeader"
           BasedOn="{StaticResource DefaultTableViewRowHeaderStyle}" />
    
    <Style BasedOn="{StaticResource DefaultTableViewRowPresenterStyle}"
           TargetType="local:TableViewRowPresenter" />

    <Style TargetType="local:TableViewHeaderRow"
           BasedOn="{StaticResource DefaultTableViewHeaderRowStyle}" />

    <Style TargetType="local:TableViewColumnHeader"
           BasedOn="{StaticResource DefaultTableViewColumnHeaderStyle}" />

    <Style TargetType="local:TableViewCell"
           BasedOn="{StaticResource DefaultTableViewCellStyle}" />

    <Style TargetType="local:TableViewRow"
           BasedOn="{StaticResource DefaultTableViewRowStyle}" />

    <Style TargetType="local:TableView"
           BasedOn="{StaticResource DefaultTableViewStyle}" />

    <Style TargetType="controls:TableViewTimePicker"
           BasedOn="{StaticResource DefaultTableViewTimePickerStyle}" />

</ResourceDictionary>
