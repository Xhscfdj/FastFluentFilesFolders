<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="LRS.UserControls.LRSBreadcrumb"
			 x:Name="LRSB"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:local="using:LRS.UserControls"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:local1="using:BetterBreadcrumbBar.Control"
			 xmlns:ucs="using:LRS.UserControls"
			 xmlns:vm="using:LRS.ViewModels"
			 mc:Ignorable="d">
	<UserControl.Resources>
		<!-- 转换器：Bool→Visibility（隐藏最后一个分隔符） -->
		<local1:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
		<!-- 箭头旋转动画 Storyboard（预定义，复用） -->
		<Storyboard x:Key="RotateArrowStoryboard" Duration="0:0:0.2">
			<DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                             To="180" Duration="0:0:0.2">
				<DoubleAnimation.EasingFunction>
					<QuadraticEase EasingMode="EaseOut"/>
				</DoubleAnimation.EasingFunction>
			</DoubleAnimation>
		</Storyboard>
		<Storyboard x:Key="RotateArrowBackStoryboard" Duration="0:0:0.2">
			<DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                             To="0" Duration="0:0:0.2">
				<DoubleAnimation.EasingFunction>
					<QuadraticEase EasingMode="EaseOut"/>
				</DoubleAnimation.EasingFunction>
			</DoubleAnimation>
		</Storyboard>
	</UserControl.Resources>

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="30"/>
		</Grid.RowDefinitions>
		<ScrollViewer Grid.Column="0" Grid.Row="0"
					  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                      HorizontalAlignment="Left">
			<ItemsControl x:Name="BreadcrumbItemsControl" ItemsSource="{Binding Segments, ElementName=LRSB}">
				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<StackPanel Orientation="Horizontal"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>

				<ItemsControl.ItemTemplate>
					<DataTemplate x:DataType="vm:MainWindowViewModel">
						<StackPanel Orientation="Horizontal" VerticalAlignment="Center">

							<Button Command="{Binding DataContext.NavigateCommand, ElementName=RootPage}"
									CommandParameter="{Binding FullPath}" 
									Content="{Binding DisplayName}"
									Margin="0,0,2,0"/>

							<Button x:Name="ArrowButton"
									Margin="0,0,2,0"
									Tag="{Binding}">
								<Button.RenderTransform>
									<RotateTransform Angle="0"/>
								</Button.RenderTransform>
								<FontIcon Glyph="&#xE0E5;" FontSize="12" />
								<Button.Flyout>
									<MenuFlyout>

										<MenuFlyout.MenuFlyoutPresenterStyle>
											<Style TargetType="MenuFlyoutItem">
												<Setter Property="Command" 
                            Value="{Binding DataContext.NavigateCommand, ElementName=RootPage}" />
												<Setter Property="CommandParameter" 
                            Value="{Binding FullPath}" />
												<Setter Property="Text" 
                            Value="{Binding Name}" />
											</Style>
										</MenuFlyout.MenuFlyoutPresenterStyle>
									</MenuFlyout>
								</Button.Flyout>
							</Button>

						</StackPanel>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
				<!--<ItemsControl.ItemTemplate>
					<DataTemplate>
						<TextBlock Text="{Binding DisplayName}" Margin="2" Foreground="White"/>
					</DataTemplate>
				</ItemsControl.ItemTemplate>-->
			</ItemsControl>
		</ScrollViewer>

		<!-- 复制按钮（不变） -->
		<Button Grid.Column="1" Grid.Row="0"
				ToolTipService.ToolTip="复制路径"
                Command="{Binding CopyPathCommand, ElementName=LRSB}" Margin="8,0,0,0" HorizontalAlignment="Left">
			<Button.Content>
				<FontIcon Glyph="&#xE8C8;"/>
			</Button.Content>
		</Button>
	</Grid>
</UserControl>