<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="LRS.Views.FileTreeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LRS.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:LRS.ViewModels"
    mc:Ignorable="d">

    <Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>
		
		<TextBlock Text="{Binding ML.PinnedShortcutsTitle}" FontWeight="SemiBold" Foreground="Gray" Margin="10,0,0,10"/>
		<TreeView Grid.Row="1"
                  ItemsSource="{Binding RootDirectories}"
                  SelectionChanged="TreeView_SelectionChanged">
            <TreeView.ItemTemplate>
                <DataTemplate x:DataType="vm:FileSystemNodeViewModel">
                    <TreeViewItem ItemsSource="{Binding Children}"
                                  IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                                  IsSelected="{Binding IsSelected, Mode=TwoWay}">
                        <TreeViewItem.Content>
                            <StackPanel Orientation="Horizontal">
                                <Image Source="{Binding Icon}" Width="20" Height="20" />
                                <TextBlock Text="{Binding Name}" Margin="5,0,0,0" />
                            </StackPanel>
                        </TreeViewItem.Content>
                    </TreeViewItem>
                </DataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

        <Button Grid.Row="2" Click="ToggleSettings"
				Grid.Column="0"
                BorderThickness="0" Background="Transparent"
                Padding="12,8" Margin="4,0,0,4">
			<Button.Content>
				<StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Left">
					<FontIcon x:Name="SettingsBtnIcon" Glyph="&#xE713;" FontSize="14" HorizontalAlignment="Left"/>
					<TextBlock x:Name="SettingsBtnLabel" Text="设置" FontSize="13" HorizontalAlignment="Left"/>
				</StackPanel>
			</Button.Content>
		</Button>
    </Grid>
</Page>
